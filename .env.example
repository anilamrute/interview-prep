# LLM Provider: groq | ollama | openrouter | gemini
LLM_PROVIDER=groq

# API Key (required for groq, openrouter, gemini; not needed for ollama)
# Get your free Groq key at: https://console.groq.com/keys
LLM_API_KEY=your_api_key_here

# Model name (provider-specific defaults apply if left empty)
# Groq examples: llama3-70b-8192, mixtral-8x7b-32768, gemma-7b-it
# Ollama examples: llama3, mistral
LLM_MODEL=llama3-70b-8192

# Base URL (rarely needs changing unless using a proxy)
# LLM_BASE_URL=https://api.groq.com/openai/v1
